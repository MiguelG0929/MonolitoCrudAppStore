# IMAGEN MODELO
FROM eclipse-temurin:17.0.18_8-jdk-jammy

#PUERTO DONDE SE EJECUTA EL CONTENEDOR (INFORMATIVO)
EXPOSE 9525

#DEFINIR DIRECTORIO RAIZ DEL CONTENEDOR
WORKDIR /root

#COPIAR Y PEGAR ARCHIVOS DENTRO DEL CONTENEDOR
COPY ./pom.xml /root
COPY ./.mvn /root/.mvn
COPY ./mvnw /root

# CONVERTIR LOS FINALES DE LÍNEA A FORMATO UNIX (importante para Windows)
RUN sed -i 's/\r$//' mvnw

#PERMISOS A mvnw
RUN chmod +x ./mvnw

#DESCARGAR LAS DEPENDENCIAS
RUN ./mvnw dependency:go-offline

#COPIAR CODIGO FUENTE DENTRO DEL CONTENEDOR
COPY ./src /root/src

#CONSTRUIR NUESTRA APLICACION
RUN ./mvnw clean install -DskipTests

#LEVANTAR NUESTRA APLICACION CUANTO EL CONTENEDOR INICIE
ENTRYPOINT ["java","-jar","/root/target/crudstore-0.0.1-SNAPSHOT.jar"]